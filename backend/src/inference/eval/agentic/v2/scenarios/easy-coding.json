      "tools": [
        {
          "name": "search_symbol",
          "params": {
            "name": "string"
          }
        },
        {
          "name": "reply",
          "params": {
            "text": "string"
          }
        }
      ],
      "decoy_tools": [
        {
          "name": "delete_file",
          "params": {
            "path": "string"
          }
        }
      ],
      "expected_calls": [
        {
          "type": "call",
          "name": "search_symbol",
          "args": {
            "name": "calculate_gst"
          }
        },
        {
          "type": "call",
          "name": "reply",
          "args": {
            "text": "*billing/tax.py*"
          }
