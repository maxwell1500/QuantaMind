      "id": "es_cs_reset_password",
      "category": "agent_loop",
      "max_steps": 6,
      "max_recovery": 2,
      "prompt": "Customer 'C-1001' forgot their password and wants a reset link sent to their email on file. Look up the account, then send the reset link.",
      "world_state": {
        "C-1001": {
          "email": "asha@example.in",
          "status": "active"
        }
      },
      "tools": [
        {
          "name": "get_account",
          "params": {
            "customer_id": "string"
          }
        },
        {
          "name": "send_reset_link",
          "params": {
            "customer_id": "string",
            "email": "string"
          },
          "returns_entity": false
        }
      ],
      "decoy_tools": [
        {
          "name": "close_ticket",
          "params": {
            "ticket_id": "string"
          }
        }
      ],
      "expected_calls": [
        {
          "type": "call",
          "name": "get_account",
          "args": {
            "customer_id": "C-1001"
          }
        },
        {
          "type": "call",
          "name": "send_reset_link",
          "args": {
            "customer_id": "C-1001",
            "email": "asha@example.in"
          }
        }
      ],
      "must_not_call": [
        "close_ticket"
      ],
      "faults": [],
      "trap": {
        "note": "The email must be READ from the account lookup, not guessed. A model that calls send_reset_link before get_account (inventing the email) fails end-state."
      },
      "rubric": {
        "success_definition": "Account fetched, reset link sent to the on-file email, ticket not prematurely closed.",
        "partial_credit": false
      }
    },
