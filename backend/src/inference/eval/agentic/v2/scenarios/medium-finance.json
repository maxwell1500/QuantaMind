          "daily_cap": 200000,
          "used_today": 180000
        },
        "AC-502": {
          "kyc": "Min",
          "daily_cap": 10000,
          "used_today": 0
        },
        "AC-503": {
          "kyc": "Min",
          "daily_cap": 10000,
          "used_today": 0
