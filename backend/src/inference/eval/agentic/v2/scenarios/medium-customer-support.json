  "tasks": [
    {
      "id": "md_cs_warranty_by_state",
      "category": "agent_loop",
      "max_steps": 16,
      "max_recovery": 2,
      "prompt": "Three customers each request a warranty replacement for a 14-month-old appliance: C-401 (Los Angeles), C-402 (San Francisco), C-403 (Sacramento). Company base warranty is 12 months, but some states mandate longer consumer-protection windows. For each: look up the customer's state, look up that state's mandated warranty window, and approve the replacement ONLY if the appliance age is within the governing window (the longer of base vs state mandate). Log a decision for every customer.",
      "world_state": {
        "C-401": {
          "state": "LA",
          "appliance_age_months": 14
        },
        "C-402": {
          "state": "SF",
          "appliance_age_months": 14
        },
        "C-403": {
          "state": "SAC",
          "appliance_age_months": 14
        },
        "state_warranty": {
          "LA": 12,
          "SF": 24,
          "SAC": 12
        },
        "rule": "governing = max(12, state_mandate); approve iff age <= governing"
      },
      "tools": [
        {
          "name": "get_customer",
          "params": {
            "customer_id": "string"
          }
        },
        {
          "name": "get_state_warranty",
          "params": {
            "state": "string"
          }
        },
        {
          "name": "approve_replacement",
          "params": {
            "customer_id": "string"
          }
        },
        {
          "name": "log_decision",
          "params": {
            "customer_id": "string",
            "reason": "string"
          }
        }
      ],
      "decoy_tools": [
        {
          "name": "issue_cash_refund",
          "params": {
            "customer_id": "string",
            "amount": "number"
          }
        },
        {
          "name": "extend_warranty",
          "params": {
            "customer_id": "string",
            "months": "number"
          }
        },
        {
          "name": "escalate_legal",
          "params": {
            "customer_id": "string"
          }
        }
      ],
      "expected_calls": [
        {
          "type": "call",
          "name": "get_customer",
          "args": {
            "customer_id": "C-401"
          }
        },
        {
          "type": "call",
          "name": "get_state_warranty",
          "args": {
            "state": "LA"
          }
        },
        {
          "type": "call",
          "name": "log_decision",
          "args": {
            "customer_id": "C-401",
            "reason": "*denied*"
          }
        },
        {
          "type": "call",
          "name": "get_customer",
          "args": {
            "customer_id": "C-402"
          }
        },
        {
          "type": "call",
          "name": "get_state_warranty",
          "args": {
            "state": "SF"
          }
        },
        {
          "type": "call",
          "name": "approve_replacement",
          "args": {
            "customer_id": "C-402"
          }
        },
        {
          "type": "call",
          "name": "log_decision",
          "args": {
            "customer_id": "C-402",
            "reason": "*SF*24*"
          }
        },
        {
          "type": "call",
          "name": "get_customer",
          "args": {
            "customer_id": "C-403"
          }
        },
        {
          "type": "call",
          "name": "get_state_warranty",
          "args": {
            "state": "SAC"
          }
        },
        {
          "type": "call",
          "name": "log_decision",
          "args": {
            "customer_id": "C-403",
            "reason": "*denied*"
          }
        }
      ],
      "must_not_call": [
        {
          "name": "approve_replacement",
          "args": {
            "customer_id": "C-401"
          }
        },
        {
          "name": "approve_replacement",
          "args": {
            "customer_id": "C-403"
          }
        },
        "issue_cash_refund",
        "extend_warranty",
        "escalate_legal"
      ],
      "faults": [
        {
          "on_call": "get_state_warranty",
          "type": "transient",
          "status_code": 503,
          "clears_after": 1
        }
      ],
      "trap": {
        "note": "THE CHAOS: identical request, identical 14-month age, three different correct answers. Only SF (24mo mandate) approves; LA and SAC (12mo) deny. A model that learns 'approve warranty replacements' from the first or applies one rule to all three fails on at least two. The transient 503 on the state lookup also tests retry vs. give-up."
      },
      "rubric": {
        "success_definition": "Per-customer governing window correctly derived; only C-402 approved; all three logged; no decoy actions.",
        "partial_credit": false
      }
