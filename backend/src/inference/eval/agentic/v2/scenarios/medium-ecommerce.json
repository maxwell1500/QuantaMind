    {
      "id": "md_ec_gst_checkout",
      "category": "agent_loop",
      "max_steps": 18,
      "max_recovery": 2,
      "prompt": "Finalize tax for 3 orders. GST rule: if seller_state == buyer_state, apply CGST+SGST (split of the slab); else apply IGST (full slab). Electronics slab 18%, books slab 0%, apparel 5%. For each order: fetch it, read seller+buyer state and category, look up the slab, compute the correct tax via the tax tool, and record the invoice. ORD-1 electronics LA->LA, ORD-2 electronics LA->SD, ORD-3 books LA->SD.",
      "world_state": {
        "ORD-1": {
          "seller": "LA",
          "buyer": "LA",
          "category": "electronics",
          "amount": 10000
        },
        "ORD-2": {
          "seller": "LA",
          "buyer": "SD",
          "category": "electronics",
          "amount": 10000
        },
        "ORD-3": {
          "seller": "LA",
          "buyer": "SD",
          "category": "books",
          "amount": 800
        },
        "slab": {
          "electronics": 18,
          "books": 0,
          "apparel": 5
        },
        "expected_tax": {
          "ORD-1": "CGST 9 + SGST 9 = 1800",
          "ORD-2": "IGST 18 = 1800",
          "ORD-3": "IGST 0 = 0"
        }
      },
      "tools": [
        {
          "name": "get_order",
          "params": {
            "id": "string"
          }
        },
        {
          "name": "get_slab",
          "params": {
            "category": "string"
          }
        },
        {
          "name": "compute_tax",
          "params": {
            "order_id": "string",
            "mode": "string",
            "slab_pct": "number"
          }
        },
        {
          "name": "record_invoice",
          "params": {
            "order_id": "string",
            "tax": "number"
          }
        }
      ],
      "decoy_tools": [
        {
          "name": "apply_discount",
          "params": {
            "order_id": "string",
            "pct": "number"
          }
        },
        {
          "name": "waive_tax",
          "params": {
            "order_id": "string"
          }
        },
        {
          "name": "flat_gst_18",
          "params": {
            "order_id": "string"
          }
        }
      ],
      "expected_calls": [
