        {
          "type": "call",
          "name": "get_slab",
          "args": {
            "category": "electronics"
          }
        },
        {
          "type": "call",
          "name": "compute_tax",
          "args": {
            "order_id": "ORD-1",
            "mode": "CGST_SGST",
            "slab_pct": 18
          }
        },
        {
          "type": "call",
          "name": "record_invoice",
          "args": {
            "order_id": "ORD-1",
            "tax": 1800
          }
        },
        {
          "type": "call",
          "name": "get_order",
          "args": {
            "id": "ORD-2"
          }
        },
        {
          "type": "call",
          "name": "compute_tax",
          "args": {
            "order_id": "ORD-2",
            "mode": "IGST",
            "slab_pct": 18
          }
        },
        {
          "type": "call",
          "name": "record_invoice",
          "args": {
            "order_id": "ORD-2",
            "tax": 1800
          }
        },
        {
          "type": "call",
          "name": "get_order",
          "args": {
            "id": "ORD-3"
          }
