        {
          "type": "call",
          "name": "get_slab",
          "args": {
            "category": "books"
          }
        },
        {
          "type": "call",
          "name": "compute_tax",
          "args": {
            "order_id": "ORD-3",
            "mode": "IGST",
            "slab_pct": 0
          }
        },
        {
          "type": "call",
          "name": "record_invoice",
          "args": {
            "order_id": "ORD-3",
            "tax": 0
          }
        }
      ],
      "must_not_call": [
        "apply_discount",
        "waive_tax",
        "flat_gst_18"
      ],
      "faults": [
        {
          "on_call": "get_slab",
