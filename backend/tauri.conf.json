{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuantaMind",
  "version": "0.2.0",
  "identifier": "dev.quantamind.app",
  "build": {
    "beforeDevCommand": "pnpm --dir frontend dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir frontend build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      { "title": "QuantaMind", "width": 1000, "height": 700 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": { "binaries/": "binaries/", "../docs/prompts/": "prompts/", "../docs/evals/": "evals/" },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "macos.entitlements"
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-common",
          "libssl3",
          "libasound2t64",
          "libpulse0",
          "ffmpeg"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://quantamind.co/releases/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDNzhGRkYwNzQ4MTIxNEYKUldSUElZRjA4UDk0bkhQUHNFbnJIaS9FTXJ0Mmh5d3VIVmhSWFo0bmoxZWhBTnViYTdteCtDR1AK"
    }
  }
}
