[
  {
    "id": "finance-transfer-balance",
    "category": "agentic",
    "prompt": "You are a banking automation agent. Step 1: call get_balance for account \"ACC-001\". Step 2: transfer the full returned balance to account \"ACC-999\" using execute_transfer. Respond with ONLY one JSON tool call per turn, no prose. Format: {\"name\": \"<tool>\", \"args\": { ... }}.",
    "tools": [
      { "name": "get_balance", "description": "Get the current balance of an account", "parameters": { "type": "object", "properties": { "account_id": { "type": "string" } }, "required": ["account_id"] } },
      { "name": "execute_transfer", "description": "Transfer funds to a destination account", "parameters": { "type": "object", "properties": { "amount": { "type": "number" }, "to_account": { "type": "string" } }, "required": ["amount", "to_account"] } }
    ],
    "expected": { "type": "no_call" },
    "agentic": {
      "mocks": [
        { "call": { "name": "get_balance", "args": { "account_id": "ACC-001" } }, "response": "{\"account_id\":\"ACC-001\",\"balance\":500.00,\"currency\":\"USD\"}" }
      ],
      "end_state": { "require_sequence": [
        { "tool": "get_balance", "args": { "account_id": "ACC-001" } },
        { "tool": "execute_transfer", "args": { "amount": 500.00, "to_account": "ACC-999" } }
      ] },
      "k": 3,
      "max_steps": 6
    }
  },
  {
    "id": "inventory-restock",
    "category": "agentic",
    "prompt": "You are a warehouse agent. Step 1: call check_stock for sku \"SKU-22\". Step 2: place a purchase order for 50 units of SKU-22 with create_purchase_order. Respond with ONLY one JSON tool call per turn.",
    "tools": [
      { "name": "check_stock", "description": "Check current stock level for a SKU", "parameters": { "type": "object", "properties": { "sku": { "type": "string" } }, "required": ["sku"] } },
      { "name": "create_purchase_order", "description": "Order more units of a SKU", "parameters": { "type": "object", "properties": { "sku": { "type": "string" }, "quantity": { "type": "number" } }, "required": ["sku", "quantity"] } }
    ],
    "expected": { "type": "no_call" },
    "agentic": {
      "mocks": [
        { "call": { "name": "check_stock", "args": { "sku": "SKU-22" } }, "response": "{\"sku\":\"SKU-22\",\"stock\":4,\"reorder_point\":20}" }
      ],
      "end_state": { "require_sequence": [
        { "tool": "check_stock", "args": { "sku": "SKU-22" } },
        { "tool": "create_purchase_order", "args": { "sku": "SKU-22", "quantity": 50 } }
      ] },
      "k": 3,
      "max_steps": 6
    }
  },
  {
    "id": "support-triage",
    "category": "agentic",
    "prompt": "You are a support triage agent. Step 1: get_ticket \"T-100\". Step 2: assign_agent the ticket to agent \"alice\". Step 3: close_ticket with resolution \"resolved\". Respond with ONLY one JSON tool call per turn.",
    "tools": [
      { "name": "get_ticket", "description": "Fetch a support ticket", "parameters": { "type": "object", "properties": { "ticket_id": { "type": "string" } }, "required": ["ticket_id"] } },
      { "name": "assign_agent", "description": "Assign a ticket to an agent", "parameters": { "type": "object", "properties": { "ticket_id": { "type": "string" }, "agent": { "type": "string" } }, "required": ["ticket_id", "agent"] } },
      { "name": "close_ticket", "description": "Close a ticket with a resolution", "parameters": { "type": "object", "properties": { "ticket_id": { "type": "string" }, "resolution": { "type": "string" } }, "required": ["ticket_id", "resolution"] } }
    ],
    "expected": { "type": "no_call" },
    "agentic": {
      "mocks": [
        { "call": { "name": "get_ticket", "args": { "ticket_id": "T-100" } }, "response": "{\"ticket_id\":\"T-100\",\"priority\":\"high\",\"topic\":\"billing\"}" },
        { "call": { "name": "assign_agent", "args": { "ticket_id": "T-100", "agent": "alice" } }, "response": "{\"assigned\":true}" }
      ],
      "end_state": { "require_sequence": [
        { "tool": "get_ticket", "args": { "ticket_id": "T-100" } },
        { "tool": "assign_agent", "args": { "ticket_id": "T-100", "agent": "alice" } },
        { "tool": "close_ticket", "args": { "ticket_id": "T-100", "resolution": "resolved" } }
      ] },
      "k": 3,
      "max_steps": 8
    }
  },
  {
    "id": "weather-then-book",
    "category": "agentic",
    "prompt": "You are a travel agent. Step 1: get_weather for city \"Paris\". Step 2: book_flight with destination \"Paris\" and when \"2026-07-01\". Respond with ONLY one JSON tool call per turn.",
    "tools": [
      { "name": "get_weather", "description": "Get the weather forecast for a city", "parameters": { "type": "object", "properties": { "city": { "type": "string" } }, "required": ["city"] } },
      { "name": "book_flight", "description": "Book a flight to a destination on a date", "parameters": { "type": "object", "properties": { "destination": { "type": "string" }, "when": { "type": "string" } }, "required": ["destination", "when"] } }
    ],
    "expected": { "type": "no_call" },
    "agentic": {
      "mocks": [
        { "call": { "name": "get_weather", "args": { "city": "Paris" } }, "response": "{\"city\":\"Paris\",\"forecast\":\"sunny\",\"high_c\":27}" }
      ],
      "end_state": { "require_sequence": [
        { "tool": "get_weather", "args": { "city": "Paris" } },
        { "tool": "book_flight", "args": { "destination": "Paris", "when": "2026-07-01" } }
      ] },
      "k": 3,
      "max_steps": 6
    }
  },
  {
    "id": "devops-deploy",
    "category": "agentic",
    "prompt": "You are a CI/CD agent deploying branch \"main\". Step 1: run_tests for branch \"main\". Step 2: build_image for branch \"main\". Step 3: deploy image \"app:main\" to env \"production\". Respond with ONLY one JSON tool call per turn.",
    "tools": [
      { "name": "run_tests", "description": "Run the test suite for a branch", "parameters": { "type": "object", "properties": { "branch": { "type": "string" } }, "required": ["branch"] } },
      { "name": "build_image", "description": "Build a container image for a branch", "parameters": { "type": "object", "properties": { "branch": { "type": "string" } }, "required": ["branch"] } },
      { "name": "deploy", "description": "Deploy an image to an environment", "parameters": { "type": "object", "properties": { "image": { "type": "string" }, "env": { "type": "string" } }, "required": ["image", "env"] } }
    ],
    "expected": { "type": "no_call" },
    "agentic": {
      "mocks": [
        { "call": { "name": "run_tests", "args": { "branch": "main" } }, "response": "{\"passed\":true,\"failed\":0}" },
        { "call": { "name": "build_image", "args": { "branch": "main" } }, "response": "{\"image\":\"app:main\"}" }
      ],
      "end_state": { "require_sequence": [
        { "tool": "run_tests", "args": { "branch": "main" } },
        { "tool": "build_image", "args": { "branch": "main" } },
        { "tool": "deploy", "args": { "image": "app:main", "env": "production" } }
      ] },
      "k": 3,
      "max_steps": 8
    }
  },
  {
    "id": "data-pipeline-elt",
    "category": "agentic",
    "prompt": "You are a data pipeline agent. Step 1: extract from source \"s3://raw\" (returns a dataset id). Step 2: transform that dataset id. Step 3: load the transformed dataset id into target \"warehouse\". Step 4: verify target \"warehouse\". Use the dataset ids returned by each tool. Respond with ONLY one JSON tool call per turn.",
    "tools": [
      { "name": "extract", "description": "Extract raw data from a source", "parameters": { "type": "object", "properties": { "source": { "type": "string" } }, "required": ["source"] } },
      { "name": "transform", "description": "Transform a dataset", "parameters": { "type": "object", "properties": { "dataset": { "type": "string" } }, "required": ["dataset"] } },
      { "name": "load", "description": "Load a dataset into a target", "parameters": { "type": "object", "properties": { "dataset": { "type": "string" }, "target": { "type": "string" } }, "required": ["dataset", "target"] } },
      { "name": "verify", "description": "Verify a target's loaded data", "parameters": { "type": "object", "properties": { "target": { "type": "string" } }, "required": ["target"] } }
    ],
    "expected": { "type": "no_call" },
    "agentic": {
      "mocks": [
        { "call": { "name": "extract", "args": { "source": "s3://raw" } }, "response": "{\"dataset\":\"ds-1\"}" },
        { "call": { "name": "transform", "args": { "dataset": "ds-1" } }, "response": "{\"dataset\":\"ds-1-clean\"}" },
        { "call": { "name": "load", "args": { "dataset": "ds-1-clean", "target": "warehouse" } }, "response": "{\"rows\":1000}" }
      ],
      "end_state": { "require_sequence": [
        { "tool": "extract", "args": { "source": "s3://raw" } },
        { "tool": "transform", "args": { "dataset": "ds-1" } },
        { "tool": "load", "args": { "dataset": "ds-1-clean", "target": "warehouse" } },
        { "tool": "verify", "args": { "target": "warehouse" } }
      ] },
      "k": 3,
      "max_steps": 10
    }
  },
  {
    "id": "user-onboard",
    "category": "agentic",
    "prompt": "You are an onboarding agent. Step 1: create_user with email \"bob@acme.com\" and name \"Bob\". Step 2: send_welcome_email to \"bob@acme.com\". Respond with ONLY one JSON tool call per turn.",
    "tools": [
      { "name": "create_user", "description": "Create a new user account", "parameters": { "type": "object", "properties": { "email": { "type": "string" }, "name": { "type": "string" } }, "required": ["email", "name"] } },
      { "name": "send_welcome_email", "description": "Send the welcome email to a user", "parameters": { "type": "object", "properties": { "email": { "type": "string" } }, "required": ["email"] } }
    ],
    "expected": { "type": "no_call" },
    "agentic": {
      "mocks": [
        { "call": { "name": "create_user", "args": { "email": "bob@acme.com", "name": "Bob" } }, "response": "{\"user_id\":\"u-7\",\"email\":\"bob@acme.com\"}" }
      ],
      "end_state": { "require_sequence": [
        { "tool": "create_user", "args": { "email": "bob@acme.com", "name": "Bob" } },
        { "tool": "send_welcome_email", "args": { "email": "bob@acme.com" } }
      ] },
      "k": 3,
      "max_steps": 6
    }
  },
  {
    "id": "refund-flow",
    "category": "agentic",
    "prompt": "You are a refunds agent processing order \"ORD-50\". Step 1: lookup_order \"ORD-50\" (returns the order total). Step 2: validate_refund for \"ORD-50\". Step 3: issue_refund for \"ORD-50\" for the full order total. Respond with ONLY one JSON tool call per turn.",
    "tools": [
      { "name": "lookup_order", "description": "Look up an order", "parameters": { "type": "object", "properties": { "order_id": { "type": "string" } }, "required": ["order_id"] } },
      { "name": "validate_refund", "description": "Check whether an order is refund-eligible", "parameters": { "type": "object", "properties": { "order_id": { "type": "string" } }, "required": ["order_id"] } },
      { "name": "issue_refund", "description": "Issue a refund for an order", "parameters": { "type": "object", "properties": { "order_id": { "type": "string" }, "amount": { "type": "number" } }, "required": ["order_id", "amount"] } }
    ],
    "expected": { "type": "no_call" },
    "agentic": {
      "mocks": [
        { "call": { "name": "lookup_order", "args": { "order_id": "ORD-50" } }, "response": "{\"order_id\":\"ORD-50\",\"total\":75.00,\"status\":\"delivered\"}" },
        { "call": { "name": "validate_refund", "args": { "order_id": "ORD-50" } }, "response": "{\"eligible\":true}" }
      ],
      "end_state": { "require_sequence": [
        { "tool": "lookup_order", "args": { "order_id": "ORD-50" } },
        { "tool": "validate_refund", "args": { "order_id": "ORD-50" } },
        { "tool": "issue_refund", "args": { "order_id": "ORD-50", "amount": 75.00 } }
      ] },
      "k": 3,
      "max_steps": 8
    }
  }
]
